# ─── AI (Anthropic via Azure OpenAI endpoint) ─────────────────────────
AI_API_KEY=sk-ant-...
AI_BASE_URL=https://...
AI_MODEL=claude-sonnet-4-6

# ─── Auth (NextAuth v5 with Google OAuth) ─────────────────────────────
AUTH_SECRET=...
AUTH_GOOGLE_ID=...
AUTH_GOOGLE_SECRET=...

# ─── Razorpay ────────────────────────────────────────────────────────
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
# Razorpay OAuth (for merchants connecting their own account)
RAZORPAY_OAUTH_CLIENT_ID=...
RAZORPAY_OAUTH_CLIENT_SECRET=...

# ─── Credentials encryption ───────────────────────────────────────────
# AES-256-GCM key encrypting merchant Razorpay secrets / OAuth tokens at rest.
# Must be 64 hex chars (32 bytes). Generate with: openssl rand -hex 32
# WARNING: rotating this key requires re-encrypting all stored merchant
# credentials first — run `npm run reencrypt-credentials` (see scripts/).
CREDENTIALS_ENC_KEY=...

# ─── Storage ──────────────────────────────────────────────────────────
# Vercel Blob (production) — falls back to local fs if unset
BLOB_READ_WRITE_TOKEN=...

# Redis / Upstash KV (for rate limiting, sessions, caching)
# Falls back to in-memory if unset
KV_URL=redis://...
KV_REST_API_URL=https://...
KV_REST_API_TOKEN=...

# ─── Monitoring ───────────────────────────────────────────────────────
SENTRY_DSN=https://...
SENTRY_ORG=your-org
SENTRY_PROJECT=smart-pages
LOG_LEVEL=info

# ─── Speech ───────────────────────────────────────────────────────────
WHISPER_API_KEY=...
WHISPER_ENDPOINT=https://...
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=...

# ─── Optional ─────────────────────────────────────────────────────────
# Primary owner email for legacy pages created before auth
PRIMARY_OWNER_EMAIL=you@example.com
# Firecrawl API key (alternative web scraper — falls back to Jina Reader)
FIRECRAWL_API_KEY=fc-...

# ─── Database (AWS RDS — PostgreSQL) ──────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/smart_pages
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20
